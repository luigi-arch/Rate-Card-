# Supabase project that stores rate-card leads in the `ratecard_leads` table.
# The publishable (anon) key is safe to expose: RLS only permits INSERTs.
# These are also baked into src/lib/supabase.ts as defaults, so they're optional.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Brief emails (Gmail / Google Workspace SMTP). Requires 2FA + an App Password.
# Without these, leads still save to Supabase — emails are just skipped.
GMAIL_USER=sales@sidestreetmalta.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Optional overrides:
# GMAIL_FROM="SideStreet <sales@sidestreetmalta.com>"
# GMAIL_HOST=smtp.gmail.com
# GMAIL_PORT=465

# Google Calendar appointment-schedule booking page (public URL).
# Powers the embedded "book a call" step after a brief is submitted.
NEXT_PUBLIC_BOOKING_URL=https://calendar.google.com/calendar/appointments/schedules/XXXX
