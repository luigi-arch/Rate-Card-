# Supabase project that stores rate-card leads in the `ratecard_leads` table.
# The publishable (anon) key is safe to expose: RLS only permits INSERTs.
# Copy to .env.local for local dev, and set these in your host (e.g. Vercel).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
